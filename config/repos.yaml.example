# Copy to config/repos.yaml (gitignored). Provide entries before Phase 4.
# MCP tools use `id` (e.g. api-backend); owner/name resolved in tools/cicd.py.

repos:
  - id: flexink-api
    owner: YOUR_GITHUB_USERNAME_OR_ORG
    name: YOUR_REPO_NAME
    default_branch: main
    linked_servers:
      - fct-droplet
      - linode
    linked_services:
      - test-nginx
      - FlexInk
